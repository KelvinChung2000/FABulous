set_io clk1 X0Y1/A
set_io rst  X0Y1/B
set_io ena  X0Y2/A

set_io a[0] X0Y3/A
set_io a[1] X0Y3/B
set_io a[2] X0Y4/A
set_io a[3] X0Y4/B

set_io b[0] X0Y5/A
set_io b[1] X0Y5/B
set_io b[2] X0Y6/A
set_io b[3] X0Y6/B

set_io c[0] X0Y7/A
set_io c[1] X0Y7/B
set_io c[2] X0Y8/A
set_io c[3] X0Y8/B
set_io c[4] X0Y9/A

set_io d[0] X0Y10/A
set_io d[1] X0Y10/B
set_io d[2] X0Y11/A
set_io d[3] X0Y11/B
set_io d[4] X0Y12/A
set_io d[5] X0Y12/B
set_io d[6] X0Y13/A
set_io d[7] X0Y13/B

# Multiplication width is held to 3 bits per operand — at 4 bits the
# LUT-based multiplier triggers a SimFailure in icarus on the demo fabric.
set_io mult_a[0] X0Y3/A
set_io mult_a[1] X0Y3/B
set_io mult_a[2] X0Y4/A
set_io mult_b[0] X0Y5/A
set_io mult_b[1] X0Y5/B
set_io mult_b[2] X0Y6/A
set_io product[0] X0Y7/A
set_io product[1] X0Y7/B
set_io product[2] X0Y8/A
set_io product[3] X0Y8/B
set_io product[4] X0Y9/A
set_io product[5] X0Y9/B

set_io all[0] X0Y3/A
set_io all[1] X0Y3/B
set_io all[2] X0Y4/A
set_io all[3] X0Y4/B
